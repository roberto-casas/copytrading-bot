# ── Dry-run mode ──────────────────────────────────────────────────────────────
# Set to true to run the bot without placing real orders (paper trading).
# Polymarket credentials are NOT required when DRY_RUN=true.
DRY_RUN=false

# Virtual starting balance for dry-run simulations (default: 100 USDC).
DRY_RUN_BALANCE_USDC=100

# ── Web dashboard ─────────────────────────────────────────────────────────────
# Port for the web dashboard (default: 8080).
# Open http://localhost:8080 in your browser to see the bot status.
DASHBOARD_PORT=8080

# ── Optional skip-pressure webhook alerts ────────────────────────────────────
# Set to a webhook endpoint to receive POST JSON alerts on skip-pressure spikes.
# Leave empty to disable outbound alerts.
SKIP_ALERT_WEBHOOK_URL=

# Per-reason threshold in trailing 1h to trigger an alert (default: 25).
SKIP_ALERT_1H_THRESHOLD=25

# Minimum seconds between repeated alerts when spike composition is unchanged.
SKIP_ALERT_COOLDOWN_SECS=900

# How often the alert worker evaluates skip-pressure metrics (seconds).
SKIP_ALERT_EVAL_INTERVAL_SECS=60

# Optional HMAC secret; when set, webhook requests include X-CopyBot-Signature.
SKIP_ALERT_HMAC_SECRET=

# Webhook retry policy.
SKIP_ALERT_MAX_RETRIES=3
SKIP_ALERT_RETRY_BACKOFF_MS=500

# Restart-safe runtime state storage.
STATE_DIR=.runtime
STATE_FLUSH_INTERVAL_SECS=30
ACCOUNT_SYNC_INTERVAL_SECS=120

# ── Polymarket credentials ────────────────────────────────────────────────────
# Ethereum private key for signing CLOB orders (hex, with or without 0x prefix)
# NOT required when DRY_RUN=true
POLYMARKET_PRIVATE_KEY=0x...

# Polymarket CLOB API key (UUID format — run `polymarket clob create-api-key` to generate)
POLYMARKET_API_KEY=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# CLOB API secret
POLYMARKET_API_SECRET=...

# CLOB API passphrase
POLYMARKET_API_PASSPHRASE=...

# Ethereum address corresponding to POLYMARKET_PRIVATE_KEY
POLYMARKET_ADDRESS=0x...

# ── Investigation settings ────────────────────────────────────────────────────
# How many leaderboard traders to evaluate each cycle (1-50, default: 50)
LEADERBOARD_FETCH_SIZE=50

# Maximum whales to track simultaneously (1-10, default: 10)
MAX_WHALES=10

# Minimum number of resolved trades a candidate must have (default: 10)
MIN_RESOLVED_TRADES=10

# How often to re-run the investigation cycle in seconds (default: 3600 = 1 h)
INVESTIGATION_INTERVAL_SECS=3600

# Bayesian prior for win-rate smoothing (Beta(alpha, beta)).
BAYES_PRIOR_ALPHA=2.0
BAYES_PRIOR_BETA=2.0

# Conservative lower-bound z-score (1.64 ~= 95% one-sided bound).
BAYES_CONFIDENCE_Z=1.64

# ── Trading settings ──────────────────────────────────────────────────────────
# Total USDC bankroll available to the bot (default: 1000.0)
BANKROLL_USDC=1000.0

# Fractional Kelly multiplier — 0.5 = half-Kelly (recommended), 1.0 = full Kelly
KELLY_FRACTION=0.5

# Hard cap: maximum fraction of bankroll per single position (default: 0.20 = 20%)
MAX_POSITION_FRACTION=0.20

# How often the trading thread polls whale trades via Data API (seconds, default: 30)
POLL_INTERVAL_SECS=30

# Net-edge model costs (bps).
ESTIMATED_FEE_BPS=20.0
ESTIMATED_SLIPPAGE_BPS=25.0
ADVERSE_SELECTION_BPS=10.0
MIN_NET_EDGE_BPS=15.0

# Execution protection (bps).
MAX_COPY_PRICE_DRIFT_BPS=150.0
MAX_ORDER_SLIPPAGE_BPS=80.0

# Risk circuit breakers.
DAILY_LOSS_LIMIT_USDC=150.0
MAX_CONSECUTIVE_LOSSES=8
MAX_NOTIONAL_PER_MARKET_USDC=350.0

# ── Log level ─────────────────────────────────────────────────────────────────
RUST_LOG=info
